## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
# Standard .NET ignore rules

# Ignore bin and obj folders in any directory
**/bin/
**/obj/
# Specifically catch those literal backslash paths
**bin\\**
**obj\\**


[Bb]in/
[Oo]bj/
# Handle the literal backslash paths specifically
*bin\\*
*obj\\*
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

.claude/

*.pdf
*.txt

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Uploads directory
src/HRCMS.API/wwwroot/uploads/

documentation/
publish/
